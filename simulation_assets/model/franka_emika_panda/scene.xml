<mujoco model="panda scene">
  <include file="panda.xml"/>

  <statistic center="0.3 0 0.4" extent="1"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
             markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane"
              texuniform="true" texrepeat="5 5" reflectance="0.2"/>

    <material name="vla_red" rgba="1 0 0 1"/>

  </asset>

  <worldbody>
    <!-- LIGHT -->
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>

    <!-- FLOOR -->
    <geom name="floor"
      type="plane"
      size="0 0 0.05"
      material="groundplane"/>


    <body name="world_frame" pos="0 0 0">
      <geom name="X" type="cylinder" size="0.005" fromto="0 0 0 0.3 0 0" rgba="1 0 0 1" contype="0" conaffinity="0"/>
      <geom name="Y" type="cylinder" size="0.005" fromto="0 0 0 0 0.3 0" rgba="0 1 0 1" contype="0" conaffinity="0"/>
      <geom name="Z" type="cylinder" size="0.005" fromto="0 0 0 0 0 0.3" rgba="1 0 1 1" contype="0" conaffinity="0"/>

    </body>

    <body name="target_ghost" mocap="true" pos="0.1 0 0.7">
      <geom type="sphere" size="0.02" rgba="0.2 0.4 0.8 1" contype="0" conaffinity="0"/>
    </body>

      
    <camera name="static_cam"
      pos="0.05 -0.75 1.3"
      euler="0.8 -0.3236 -0.26"
      fovy="45"/>

    <!-- STATIC DESK -->
   <body name="desk" pos="0.6 0 0.1"> 
      <geom name="desk_geom"
            type="box"
            size="0.3 0.3 0.1" 
            rgba="0.7 0.5 0.3 1"
            contype="1"
            conaffinity="1"/>
  </body>

    <!-- MOVABLE BLOCK -->
  <body name="green" pos="0.6 0.2 0.53">
    <freejoint/>
    <geom name="block_geom1"
          type="box"
          size="0.03 0.03 0.03"
          rgba="0.2 0.8 0.2 1"
          density="500"/>
  </body>


  <body name="red" pos="0.6 -0.2 0.5">
      <freejoint/>
      <geom name="block_geom2"
            type="box"
            size="0.03 0.03 0.03"
            rgba="1 0 0 1"
            density="500"/>
  </body>

  <!-- <body name="target_body" pos="0.4 0.2 0.3">
    <geom type="sphere" size="0.03"
          rgba="0 1 0 1"
          contype="0" conaffinity="0"/>
  </body> -->






  </worldbody>
</mujoco>
